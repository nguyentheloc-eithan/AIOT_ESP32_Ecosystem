# AIOT ESP32 Ecosystem - Infrastructure Configuration
# Copy this file to .env and update with your settings

# ==================== MQTT Settings ====================
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=9001

# MQTT Authentication (leave empty for development)
MQTT_USERNAME=
MQTT_PASSWORD=

# ==================== PocketBase Settings ====================
POCKETBASE_PORT=8090
POCKETBASE_ADMIN_EMAIL=admin@aiot.local
POCKETBASE_ADMIN_PASSWORD=

# ==================== Backend Settings ====================
BACKEND_PORT=8080
BACKEND_ENV=development

# ==================== Frontend Settings ====================
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8080
VITE_MQTT_WS_URL=ws://localhost:9001
VITE_POCKETBASE_URL=http://localhost:8090

# ==================== Notification Settings ====================
# Firebase Cloud Messaging (Optional)
FCM_SERVER_KEY=
FCM_SENDER_ID=

# ==================== Module Settings ====================
# Default watering duration (seconds)
DEFAULT_PUMP_DURATION=300

# Moisture threshold for alerts (%)
MOISTURE_ALERT_THRESHOLD=20

# Temperature thresholds (°C)
TEMP_MIN_THRESHOLD=10
TEMP_MAX_THRESHOLD=35
